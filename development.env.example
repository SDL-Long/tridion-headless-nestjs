# Global
DISCOVERY_SERVICE_URI=https://***/discovery.svc
SITE_URL=http://localhost:3000
OAUTH_CLIENT_ID=*
OAUTH_CLIENT_SECRET=*
HTTP_TIMEOUT=10000
HTTP_MAX_REDIRECTS=5
HTTP_MAX_RETRY=3

# Caching (Set 5 mins -> basic 4 hours for most of cache items for development)
DEFAULT_CACHE_TTL=14400000
PAGE_CACHE_TTL=14400000
PAGEMETA_CACHE_TTL=14400000
HEADER_CACHE_TTL=14400000
FOOTER_CACHE_TTL=14400000
COMPONENTLIST_CACHE_TTL=3600000
COMPONENTLIST_NEWS_CACHE_TTL=86400000
NAVIGATION_CACHE_TTL=43200000
BINARY_CACHE_TTL=43200000
BINARY_LASTPUBLISHDATE_CACHE_TTL=43200000
LABEL_CACHE_TTL=43200000
REDIRECTS_CACHE_TTL=14400000
CMSCONFIGURATION_CACHE_TTL=14400000
CATEGORY_CACHE_TTL=43200000
CATEGORYWITHKEYWORD_CACHE_TTL=43200000
KEYWORD_CACHE_TTL=43200000

NAVIGATION_CACHE_TTL_CRONJOB=14400000
TAXONOMY_CACHE_TTL_CRONJOB=14400000
LABEL_CACHE_TTL_CRONJOB=14400000
NEWS_CACHE_TTL_CRONJOB=43200000

CACHE_STORE=redis
BINARY_CACHE_STORE=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false
# Optional Redis auth (RBAC). Leave unset for local no-auth Redis.
# For ElastiCache/Valkey serverless with RBAC, set these and REDIS_TLS=true.
#REDIS_USERNAME=
#REDIS_PASSWORD=

# Logging
# Defaults are production-safe: log to stdout only (CloudWatch collects it),
# level=info. For local file logs set LOG_TO_FILE=true (and LOG_LEVEL=debug).
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=./logs

DEFAULT_HEADER_PAGE=/system/default/header.html
DEFAULT_FOOTER_PAGE=/system/default/footer.html

# For Resources (Labels) in CMS
LABEL_SCHEMA=Resources

# For Redirects configured in CMS
REDIRECTS_SCHEMA=Redirects

LABEL_TYPE=COMMON,CUSTOM
CMS_CONFIGURATION_TYPE=TEST

#domain url for s3 bucket files
s3BucketUrl=https://tridion-develop.s3.***.amazonaws.com/

NODE_OPTIONS=--max-old-space-size=4096

# CORS — separate multiple domains with a semicolon (;); set to * to allow all origins
# e.g. ALLOWED_ORIGINS=https://***.com;
# e.g. ALLOWED_ORIGINS=*
ALLOWED_ORIGINS=*;

# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # #
# For front-end rendering                                   #
# Please put this views configuration item area last        #
# # # # # # # # # # # # # # # # # # # # # # # # # # # # # # #

# Page Views ('p' + CMS Page Template Id = page view)
p65566=Home
p65577=Default

# Component Views ('c' + CMS Component Schema Id = component view)
c65656=Logo
